SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service_role_key_here
ADMIN_SECRET=choose-a-secure-password

# Mailjet (free: 200 emails/day, no custom domain needed)
# Get your API keys at https://app.mailjet.com/account/apikeys
MJ_APIKEY_PUBLIC=your_mailjet_api_key
MJ_APIKEY_PRIVATE=your_mailjet_secret_key
MAILJET_FROM_EMAIL=your-verified-sender@email.com
MAILJET_FROM_NAME="Date Slot"

# Cloudflare Turnstile
# Get your keys at https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=
VITE_TURNSTILE_SITE_KEY=

# Sentry
VITE_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
